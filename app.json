{
  "expo": {
    "name": "kuwait cars",
    "slug": "kuwaitcars",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "xcars",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "FacebookAppID": "1277409807481340",
        "FacebookClientToken": "your-client-token",
        "FacebookDisplayName": "Xcars",
        "LSApplicationQueriesSchemes": ["fbapi", "fb-messenger-api"],
        "NSFaceIDUsageDescription": "Your app uses Apple Sign-In for secure login."
      },
      "entitlements": {
        "com.apple.developer.applesignin": ["Default"]
      },
      "config": {
        "googleMapsApiKey": "AIzaSyBrYZrom9xF_auXAO9bo4Hhadj-AWu_Gvk"
      }
    },
    "android": {
      "windowSoftInputMode": "adjustResize",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.aniskhalfaoui.kuwaitcars",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBrYZrom9xF_auXAO9bo4Hhadj-AWu_Gvk"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBrYZrom9xF_auXAO9bo4Hhadj-AWu_Gvk"
        }
      }
    },
    "plugins": [
      "expo-router",
      [
        "react-native-fbsdk-next",
        {
          "appID": "1277409807481340",
          "clientToken": "your-client-token",
          "displayName": "Xcars",
          "scheme": "fb{your-app-id}",
          "advertiserIDCollectionEnabled": false,
          "autoLogAppEventsEnabled": false,
          "installAutoInitEnabled": true
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "androidClientId": "your-android-client-id.googleusercontent.com",
          "iosClientId": "your-ios-client-id.googleusercontent.com",
          "iosUrlScheme": "com.googleusercontent.apps.ios-url-schema"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-video",
      "react-native-fbsdk-next",
      "expo-localization",
      "expo-speech-recognition",
      "react-native-compressor",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "adb63c5b-db43-4cfb-9b55-72ed8ec6012d"
      }
    }
  }
}
